<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>معرض التبيان</title>
    <style>
        * { box-sizing: border-box; }
        body {
            background-color: #1a1a1a;
            color: #ffffff;
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 20px;
            text-align: center;
        }
        .gallery-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 30px;
        }
        .gallery-item img {
            width: 100%;
            height: 300px;
            object-fit: cover;
            border: 3px solid #ffffff;
        }
    </style>
</head>
<body>

    <h2>معرض تبيان</h2>
    <div class="gallery-container">
        <div class="gallery-item"><img src="DSC_4674.jpg" alt="تصوير تبيان"></div>
        <div class="gallery-item"><img src="DSC_5158.jpg" alt="تصوير تبيان"></div>
        <div class="gallery-item"><img src="DSC_5176 (1).jpg" alt="تصوير تبيان"></div>
        <div class="gallery-item"><img src="DSC_5177.jpg" alt="تصوير تبيان"></div>
    </div>

</body>
</html>

